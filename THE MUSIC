// Render tracks
function renderTracks(tracks) {
    tracksGrid.innerHTML = tracks.map(track => `
        <div class="track-card" data-track-id="${track.id}">
            <div class="track-image" style="background: linear-gradient(45deg, ${getGenreColor(track.genre)}, ${getGenreColor(track.genre, true)})">
                <i class="fas fa-music"></i>
            </div>
            <div class="track-info">
                <div class="track-title">${track.title}</div>
                <div class="track-artist">${track.artist}</div>
                <div class="track-genre">${track.genre.toUpperCase()}</div>
            </div>
        </div>
    `).join('');
}

